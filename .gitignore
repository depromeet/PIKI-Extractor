# macOS
.DS_Store

# Claude Code — commands/ 는 infra(TeamPiKi/infra) install.sh 가 SessionStart 마다 설치하는
# 공용 스킬 설치본 전용이라 디렉토리째 무시한다 (repo 전용 스킬이 생기면 core 처럼 파일 단위로 전환).
.claude/settings.local.json
.claude/worktrees/
.claude/commands/

# IDE - 개인 설정 제외
.idea/*
!.idea/codeStyles/
!.idea/inspectionProfiles/
*.iml
out/

# Gradle
.gradle/
build/

# Environment — .env* 전부 무시하되 템플릿(.env.example)은 커밋 유지
.env*
!.env.example

# Terraform — 로컬 상태/캐시와 계정값 주입 파일은 커밋 금지
.terraform/
*.tfstate
*.tfstate.*
backend.hcl
*.tfvars
